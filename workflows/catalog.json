      "entry_script": "~/catalog/scripts/content_orchestrator.py",
      "skill": "content-orchestrator",
      "steps_count": 7,
      "steps": [
        "Step 0: 参数解析 (topic + track + mode)",
        "Step 1: 选题调研 (豆包/Gemini/DeepSeek 自动降级)",
        "Step 2: 骨架生成 (三AI之一出初稿)",
        "Step 3: 精加工 (文献补充+修正)",
        "Step 4: 文章组装 (清洗+合并+写入文件)",
        "Step 5: 公众号发布 (调publish_one.py)",
        "Step 6: 视频生成 (可选, videopipeline)",
        "Step 7: 内容登记 (dashboard)"
      ],
      "prompts_summary": "TRACKS字典嵌入脚本: doubao_prompt + gemini_prompt 各两条内容线",
      "prompts_file": "~/catalog/scripts/content_orchestrator.py (112-142行)",
      "arch_doc": "~/architectures/systems/content-orchestrator/README.md",
      "output": "公众号草稿 (可选+视频)",
      "requires_manual": "发布需手动点公众号后台「发布」",
      "notes": "核心管线。运行时有人工审核闸门(每步可选继续/修改/重做/跳过)。自动降级链: 豆包→Gemini→DeepSeek。两条内容线: --track ai (提效实战派) / --track thinking (哲思)"
    },

